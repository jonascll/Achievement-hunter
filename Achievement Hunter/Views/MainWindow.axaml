<Window
    x:Class="Achievement_Hunter.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Achievement_Hunter.Views"
    xmlns:vm="using:Achievement_Hunter.ViewModels"
    Title="Achievement Hunter"
    Width="{Binding WindowWidth}"
    Height="{Binding WindowHeight}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainWindowViewModel"
    CanResize="{Binding CanResize}"
    Icon="/Assets/Achievement_Hunter.ico"
    mc:Ignorable="d">
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:GameAchievementListViewModel}">
            <views:GameAchievementsList />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:GameListViewModel}">
            <views:GameList />
        </DataTemplate>
    </Window.DataTemplates>
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <ContentControl Content="{Binding CurrentPage}" />
</Window>
